{
  "info": {
    "name": "Faex Hub CRM",
    "description": "Collection completa da API Faex Hub CRM. Faça login primeiro e copie o token para a variável {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token salvo:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@faex.edu.br\",\n  \"senha\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Cadastro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Novo Usuário\",\n  \"email\": \"novo@faex.edu.br\",\n  \"senha\": \"Test@1234\",\n  \"funcao\": \"ALUNO\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/cadastro", "host": ["{{baseUrl}}"], "path": ["auth", "cadastro"] }
          }
        },
        {
          "name": "Cadastro V2 (Vendas)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Parceiro Teste\",\n  \"email\": \"parceiro@email.com\",\n  \"senha\": \"Test@1234\",\n  \"funcao\": \"PARCEIRO\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/cadastrov2", "host": ["{{baseUrl}}"], "path": ["auth", "cadastrov2"] }
          }
        },
        {
          "name": "Esqueci Senha",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@faex.edu.br\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/esqueci-senha", "host": ["{{baseUrl}}"], "path": ["auth", "esqueci-senha"] }
          }
        },
        {
          "name": "Verificar Código Recuperação",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/esqueci-senha/SEU_CODIGO_AQUI", "host": ["{{baseUrl}}"], "path": ["auth", "esqueci-senha", "SEU_CODIGO_AQUI"] }
          }
        },
        {
          "name": "Redefinir Senha",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"SEU_TOKEN_RECUPERACAO\",\n  \"senha\": \"NovaSenha@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/redefinir-senha", "host": ["{{baseUrl}}"], "path": ["auth", "redefinir-senha"] }
          }
        },
        {
          "name": "Meu Perfil (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Atualizar Perfil",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Novo Nome\",\n  \"telefone\": \"11999990000\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/perfil", "host": ["{{baseUrl}}"], "path": ["auth", "perfil"] }
          }
        },
        {
          "name": "Alterar Senha (Autenticado)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senhaAtual\": \"Test@1234\",\n  \"novaSenha\": \"NovaSenha@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/senha", "host": ["{{baseUrl}}"], "path": ["auth", "senha"] }
          }
        }
      ]
    },
