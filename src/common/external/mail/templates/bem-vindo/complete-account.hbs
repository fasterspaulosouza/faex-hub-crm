                            <tbody>
                              <tr>
                                <td
                                  style='width:600px;'
                                  class='mj-full-width-mobile'
                                >
                                  <img
                                    alt='Imagem de topo'
                                    src='https://faexhub.s3.us-east-1.amazonaws.com/portugal/emails/boas-vindas.png'
                                    style='border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;'
                                    width='600'
                                    height='auto'
                                  />
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
