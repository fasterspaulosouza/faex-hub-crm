      <!--[if mso | IE]></td></tr></table><table align="center" border="0" cellpadding="0" cellspacing="0" class="" role="presentation" style="width:600px;" width="600" bgcolor="#ffffff" ><tr><td style="line-height:0px;font-size:0px;mso-line-height-rule:exactly;"><![endif]-->
      <div
        style='background:#ffffff;background-color:#ffffff;margin:0px auto;max-width:600px;'
      >
        <table
          align='center'
          border='0'
          cellpadding='0'
          cellspacing='0'
          role='presentation'
          style='background:#ffffff;background-color:#ffffff;width:100%;'
        >
          <tbody>
            <tr>
              <td
                style='direction:ltr;font-size:0px;padding:20px 0;text-align:center;'
              >
                <!--[if mso | IE]><table role="presentation" border="0" cellpadding="0" cellspacing="0"><tr><td class="" style="vertical-align:top;width:600px;" ><![endif]-->
                <div
                  class='mj-column-per-100 mj-outlook-group-fix'
                  style='font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;'
                >
                  <table
                    border='0'
                    cellpadding='0'
                    cellspacing='0'
                    role='presentation'
                    style='vertical-align:top;'
                    width='100%'
                  >
                    <tbody>
                      <tr>
                        <td
                          align='left'
                          class='responsive-title'
                          style='font-size:0px;padding:0 30px 10px 30px;word-break:break-word;'
                        >
                          <div
                            style='font-family:Helvetica, Arial, sans-serif;font-size:26px;font-weight:bold;line-height:140%;text-align:left;color:#475467;'
                          >Olá,
                            <span
                              style='color: #834781; font-size: 26px'
                            >{{nome}}</span></div>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='left'
                          class='responsive-text'
                          style='font-size:0px;padding:0 30px 10px 30px;word-break:break-word;'
                        >
                          <div
                            style='font-family:Helvetica, Arial, sans-serif;font-size:18px;line-height:140%;text-align:left;color:#475467;'
                          >Para completar o seu cadastro na Faex Hub, acesse sua
                            conta utilizando a senha provisória abaixo:</div>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='center'
                          class='responsive-text'
                          style='font-size:0px;padding:10px 25px;padding-bottom:0px;word-break:break-word;'
                        >
                          <div
                            style='font-family:Helvetica, Arial, sans-serif;font-size:14px;line-height:140%;text-align:center;color:#475467;'
                          ><strong> Senha provisória: </strong></div>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='center'
                          class='responsive-text'
                          style='font-size:0px;padding:10px 25px;padding-top:4px;word-break:break-word;'
                        >
                          <div
                            style='font-family:Helvetica, Arial, sans-serif;font-size:30px;letter-spacing:2px;line-height:140%;text-align:center;color:#475467;'
                          ><strong>
                              <span
                                style='background-color: #f4ebff; padding: 8px 20px; border-radius: 6px; display: inline-block'
                              > {{senha}} </span>
                            </strong></div>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='left'
                          class='responsive-text'
                          style='font-size:0px;padding:15px 30px 10px 30px;word-break:break-word;'
                        >
                          <div
                            style='font-family:Helvetica, Arial, sans-serif;font-size:17.5px;line-height:140%;text-align:left;color:#475467;'
                          >Após fazer login,
                            <strong>você poderá atualizar seus dados</strong>
                            e personalizar sua experiência no site.</div>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='left'
                          class='responsive-text'
                          style='font-size:0px;padding:0 30px 10px 30px;word-break:break-word;'
                        >
                          <div
                            style='font-family:Helvetica, Arial, sans-serif;font-size:18px;line-height:140%;text-align:left;color:#475467;'
                          >Clique no botão abaixo para entrar na sua conta:</div>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='center'
                          style='font-size:0px;padding:10px 0 0 0;word-break:break-word;'
                        >
                          <table
                            border='0'
                            cellpadding='0'
                            cellspacing='0'
                            role='presentation'
                            style='border-collapse:separate;width:300px;line-height:100%;'
                          >
                            <tbody>
                              <tr>
                                <td
                                  align='center'
                                  bgcolor='#834781'
                                  role='presentation'
                                  style='border:none;border-radius:8px;cursor:auto;mso-padding-alt:10px 25px;background:#834781;'
                                  valign='middle'
                                >
                                  <a
                                    href='https://parceiro.faexhub.pt/'
                                    style='display:inline-block;width:250px;background:#834781;color:#ffffff;font-family:Ubuntu, Helvetica, Arial, sans-serif;font-size:17px;font-weight:bold;line-height:120%;margin:0;text-decoration:none;text-transform:uppercase;padding:10px 25px;mso-padding-alt:0px;border-radius:8px;'
                                    target='_blank'
                                  >
                                    <span
                                      style='display: inline-flex; align-items: center; gap: 8px'
                                    >
                                      ACESSAR SUA CONTA
                                      <svg
                                        xmlns='http://www.w3.org/2000/svg'
                                        width='17'
                                        height='17'
                                        viewBox='0 0 48 48'
                                        fill='none'
                                      >
                                        <path
                                          d='M29.5315 23.6255H9.84375'
                                          stroke='white'
                                          stroke-width='4'
                                          stroke-linecap='round'
                                          stroke-linejoin='round'
                                        />
                                        <path
                                          d='M23.626 29.5309L29.5323 23.6246L23.626 17.7183'
                                          stroke='white'
                                          stroke-width='4'
                                          stroke-linecap='round'
                                          stroke-linejoin='round'
                                        />
                                        <path
                                          d='M7.77734 31.5007C8.62065 33.2238 9.74192 34.7962 11.0962 36.1549C16.1638 41.2225 23.785 42.7385 30.4061 39.996C37.0273 37.2534 41.3444 30.7924 41.3444 23.6257C41.3444 16.4591 37.0273 9.9981 30.4061 7.25554C23.785 4.51298 16.1638 6.02895 11.0962 11.0966C9.74194 12.4552 8.62066 14.0276 7.77734 15.7505'
                                          stroke='white'
                                          stroke-width='4'
                                          stroke-linecap='round'
                                          stroke-linejoin='round'
                                        />
                                      </svg>
                                    </span>
                                  </a>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </td>
                      </tr>
                      <tr>
                        <td
                          align='center'
                          class='responsive-logo'
                          style='font-size:0px;padding:0;padding-top:20px;word-break:break-word;'
                        >
                          <table
                            border='0'
                            cellpadding='0'
                            cellspacing='0'
                            role='presentation'
                            style='border-collapse:collapse;border-spacing:0px;'
                            class='mj-full-width-mobile'
                          >
                            <tbody>
                              <tr>
                                <td
                                  style='width:200px;'
                                  class='mj-full-width-mobile'
                                >
                                  <img
                                    alt='Logotipo Faex Hub'
                                    src='https://faexhub.s3.us-east-1.amazonaws.com/portugal/emails/logo.png'
                                    style='border:0;display:block;outline:none;text-decoration:none;height:auto;width:100%;font-size:13px;'
                                    width='200'
                                    height='auto'
                                  />
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <!--[if mso | IE]></td></tr></table><![endif]-->
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <!--[if mso | IE]></td></tr></table><![endif]-->
    </div>
