<mjml>
  <mj-head>
    <mj-attributes>
      <mj-text
        font-family="Helvetica, Arial, sans-serif"
        color="#475467"
        line-height="140%"
      />
      <mj-image align="center" padding="0" fluid-on-mobile="true" />
    </mj-attributes>

    <mj-style inline="inline">
      /* Ajustes responsivos */
      @media only screen and (max-width: 480px) {
        .responsive-text {
          font-size: 15px !important;
          padding: 0 10px !important;
        }
        .responsive-title {
          font-size: 22px !important;
        }
        .responsive-signature img {
          width: 120px !important;
        }
        .responsive-logo img {
          width: 160px !important;
        }
      }
    </mj-style>
  </mj-head>

  <mj-body background-color="#f5f5f5">
    <!-- Imagem de topo -->
    <mj-section padding="0">
      <mj-column>
        <mj-image
          src="https://faexhub.s3.us-east-1.amazonaws.com/portugal/emails/senha-alterada.png"
          width="600px"
          alt="Imagem de topo"
          fluid-on-mobile="true"
        />
      </mj-column>
    </mj-section>

    <mj-section background-color="#ffffff" padding="20px 0">
      <mj-column>
        <mj-text
          align="left"
          font-size="26px"
          font-weight="bold"
          color="#475467"
          padding="0 50px 10px 50px"
          css-class="responsive-title"
        >
          Olá, <span style="color: #834781; font-size: 26px">{{ nome }}</span>
        </mj-text>

        <mj-text
          css-class="responsive-text"
          font-size="20px"
          align="left"
          color="#475467"
          line-height="140%"
          padding="0 50px 10px 50px"
        >
          Informamos que a senha da sua conta foi alterada com sucesso.
        </mj-text>

        <mj-text
          css-class="responsive-text"
          font-size="20px"
          align="left"
          color="#475467"
          line-height="140%"
          padding="0 50px 10px 50px"
        >
          Se foi você quem fez essa alteração, não é necessário fazer mais nada.
        </mj-text>

        <mj-text
          css-class="responsive-text"
          font-size="14px"
          align="center"
          color="#475467"
          line-height="140%"
          padding="20px 50px 10px 50px"
        >
          Nota: Se não reconhece essa mudança, recomendamos <br />
          <span
            style="
              color: #834781;
              text-decoration: underline;
              text-decoration-color: #834781;
            "
          >
            redefinir sua senha
          </span>
          imediatamente.
        </mj-text>

        <mj-image
          src="https://faexhub.s3.us-east-1.amazonaws.com/portugal/emails/logo.png"
          alt="Logotipo Faex Hub"
          width="200px"
          fluid-on-mobile="true"
          padding-top="20px"
          css-class="responsive-logo"
        />
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
